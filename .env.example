# ─── Required in production ──────────────────────────────────────────────────

# MySQL/TiDB connection string for Drizzle.
# TiDB Cloud → Cluster → Connect → copy the Drizzle/General URL.
DATABASE_URL="mysql://user:pass@host:4000/thedesk"

# Session JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=""

# Anthropic API key — powers all LLM enrichment (partnerTag, sayThis,
# Ruben's Take, weekly synthesis, Substack drafts).
# console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY=""

# Admin login password. Anything strong; only you need it.
# Used at /login to gate /admin and admin-only tRPC procedures.
ADMIN_PASSWORD=""

# ─── Optional ────────────────────────────────────────────────────────────────

# Authenticates the GitHub Actions daily/weekly POSTs to /api/ingest/*.
# Generate with: openssl rand -hex 32
# Set the SAME value as a GitHub repo secret.
SCHEDULED_API_KEY=""

# Enables AI image generation for the weekly edition hero.
# Skip this and the site uses gradient placeholders for hero images.
OPENAI_API_KEY=""

# Public URL of your deployed site. Used in LinkedIn share text and the
# RSS scraper's User-Agent. Defaults to thedeskglobal.manus.space.
# Bundled into the client at build time via Vite.
VITE_SITE_URL="https://thedesk.com.au"

# Optional: Plausible analytics domain. When set, the cookieless Plausible
# script loads on every page. Set to the domain you registered at
# plausible.io (without https://). Skip to disable analytics entirely.
VITE_PLAUSIBLE_DOMAIN=""

# Optional: Resend API key for double-opt-in confirm emails. Without
# this set, the Subscribe flow still works but no email is sent
# (the row is created with a confirmToken; admin can send manually).
# https://resend.com → API Keys.
RESEND_API_KEY=""

# Optional: From-address used by the mailer. Defaults to
# "The Desk <hello@thedesk.global>". Must be on a domain you've
# verified inside Resend.
MAIL_FROM=""

# Optional: server-side site URL. Falls back to VITE_SITE_URL, then
# DEFAULT_SITE_URL. Used by the confirm-email link builder and the
# OG card route.
SITE_URL=""

# Optional dev override.
PORT="3000"
