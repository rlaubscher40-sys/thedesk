# MySQL/TiDB connection string for Drizzle
DATABASE_URL="mysql://user:pass@host:4000/thedesk"

# Session JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=""

# Manus OAuth — both server-side and exposed to the client via VITE_*
VITE_APP_ID=""
OAUTH_SERVER_URL=""
VITE_OAUTH_PORTAL_URL=""

# Manus built-in LLM + image gen + storage
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""

# Authenticates the daily/weekly scheduled task POSTs
SCHEDULED_API_KEY=""

# openId of the project owner — auto-promoted to admin role on first sign-in
OWNER_OPEN_ID=""

# Optional dev override
PORT="3000"
